<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local SDK package until it is published to nuget.org.
         Once published, remove this source and the .nupkgs/ folder. -->
    <add key="local-sdk" value=".nupkgs" />
  </packageSources>
</configuration>
