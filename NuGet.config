<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Azure Connectors SDK preview packages are published to GitHub Packages.
         Authentication is required: set GH_TOKEN env var before running dotnet restore,
         or configure credentials with: dotnet nuget update source github-azure
         See README.md for details. -->
    <add key="github-azure" value="https://nuget.pkg.github.com/Azure/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-azure>
      <add key="Username" value="USERNAME" />
      <!-- Uses GH_TOKEN or GITHUB_TOKEN environment variable. Set one before running dotnet restore. -->
      <add key="ClearTextPassword" value="%GH_TOKEN%" />
    </github-azure>
  </packageSourceCredentials>
</configuration>
